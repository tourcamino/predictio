# Vinxi/Vite SSR calls realpath() on every @napi-rs/canvas optional native path.
# With the default isolated linker, pnpm can omit linux-musl on glibc builders while
# leaving a dangling path under .pnpm/@napi-rs+canvas@*/node_modules — Preview cache
# made this visible while Production reused a warmer cache. Hoisted layout matches npm
# and keeps nested optional natives resolvable on Vercel (and local dev).
node-linker=hoisted
