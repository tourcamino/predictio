{
  "name": "predictio",
  "scripts": {
    "postinstall": "prisma generate && tsr generate",
    "dev": "node --env-file=.env node_modules/vinxi/bin/cli.mjs dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "typecheck": "tsc --noEmit -p tsconfig.ci.json",
    "typecheck:all": "tsc --noEmit",
    "lint": "eslint . -c eslint.config.mjs --max-warnings 0",
    "db:local": "docker compose -f docker-compose.dev.yml up -d",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "format": "prettier --write .",
    "smoke": "prisma validate && npm run typecheck",
    "smoke:endpoints": "node ./scripts/smoke-endpoints.mjs",
    "smoke:e2e": "node ./scripts/smoke-e2e.mjs",
    "smoke:ws": "node ./scripts/smoke-ws.mjs",
    "vps:verify": "node ./scripts/vps-verify-remote.mjs",
    "env:validate": "node ./scripts/validate-env.mjs .env"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/openai": "^1.3.23",
    "@headlessui/react": "^2.2.3",
    "@hookform/resolvers": "^5.1.1",
    "@napi-rs/canvas": "^0.1.100",
    "@openrouter/ai-sdk-provider": "^0.7.3",
    "@prisma/client": "^6.8.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-router": "^1.119.0",
    "@tanstack/react-start": "^1.119.0",
    "@tanstack/router-cli": "^1.119.0",
    "@tanstack/router-plugin": "^1.119.0",
    "@tanstack/zod-adapter": "^1.166.9",
    "@trpc/client": "^11.1.2",
    "@trpc/server": "^11.1.2",
    "@trpc/tanstack-react-query": "^11.1.2",
    "ai": "^4.3.19",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "h3": "^2.0.1-rc.21",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.12.0",
    "markdown-to-jsx": "^9.7.16",
    "minio": "^8.0.5",
    "postcss": "^8.5.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.58.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "redaxios": "^0.5.1",
    "superjson": "^2.2.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "vinxi": "0.5.3",
    "vite": "^6",
    "vite-plugin-node-polyfills": "^0.23.0",
    "ws": "^8.20.0",
    "zod": "^3.25.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@tanstack/eslint-plugin-router": "^1.115.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.25.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.5.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.31.1",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "private": true,
  "type": "module"
}
