# Predictio.live — Environment Variables
# Copy to .env / .env.local and fill in values
# See /docs/ENV.md for full documentation

# Database — Neon (prod / Vercel / locale). Imposta la password reale in `.env` (gitignored) e su Vercel.
# Usa la connection string dalla console Neon (ruolo neondb_owner). Includi sempre ?sslmode=require
# Per serverless (Vercel) spesso si usa l'host "pooler" (-pooler) che Neon mostra come "Pooled connection".
DATABASE_URL=postgresql://neondb_owner:npg_xxxxxxxxx@ep-curly-king-alfdfhen.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Prisma stdout logs (optional). Default in NODE_ENV=development: warn only (quieter terminal).
# Values: silent | none | off | verbose | all | comma list e.g. query,warn,error
# PRISMA_LOG=

# Application
# Dev server (Vinxi). Prefer IPv4 loopback on Windows so localhost in the browser works.
PORT=5173
HOST=127.0.0.1
BASE_URL=http://127.0.0.1:5173
VITE_APP_NAME=Predictio
VITE_APP_URL=
# REST Express (`/api/admin/*`, `/api/v1/*`). In dev, browser on localhost:5173 defaults to http://127.0.0.1:3001 when unset (see `src/lib/predictioApi.ts`).
# Do NOT set this to the SPA URL (e.g. http://localhost:5173) — point at the Node/Express server port.
# tRPC (`/trpc`) is served by Vinxi on the SPA origin. When VITE_API_URL is another host, the UI client uses the page origin for tRPC automatically (Express has no /trpc).
VITE_API_URL=
# Realtime WebSocket base URL (same host as API in prod). Leave unset in local dev unless you run the WS server —
# the SPA uses same-origin tRPC on Vinxi; setting only REST here avoids reconnect storms (see `src/hooks/useWebSocket.ts`).
# VITE_WS_URL=wss://api.predictio.live/ws
VITE_ENVIRONMENT=development

# Backend (VPS) security keys (C2)
# - ADMIN_API_KEY: required to call /api/admin/* and /api/developer/keys
# - BOT_API_KEY: used by bots and some internal admin tooling
ADMIN_API_KEY=
BOT_API_KEY=

# Event Curation admin REST (`X-Admin-Key`). Falls back to `ADMIN_API_KEY` if unset (see `backend/src/middleware/auth.ts`).
ADMIN_SECRET=
# Frontend: same value as ADMIN_SECRET for `/api/admin/azuro-events` and `/api/admin/events/select`
# Local dev without ADMIN_SECRET: use same as BOT_API_KEY (default `dev_bot_key`).
VITE_ADMIN_KEY=
# Frontend: gate `/admin/event-curation` (must match connected wallet; use same address as FOUNDER_WALLET)
VITE_FOUNDER_WALLET=

# Redis: caches Azuro curator GraphQL list (5 min). Optional — curator endpoints work without it.
REDIS_URL=

# Optional: Azuro subgraph for admin football picker (default = AZURO_GRAPHQL_URL / Base). Must match production indexer chain.
# AZURO_CURATOR_GRAPHQL_URL=

# Backend enforcement toggles (prod hardening)
WRITE_AUTH_REQUIRED=1

# HTTP hardening
HTTP_JSON_BODY_LIMIT=128kb

# Usage retention (days)
API_USAGE_RETENTION_DAYS=30
API_USAGE_ENABLED=1

# WebSocket hardening (C3+ hardening)
WS_AUTH_REQUIRED=1
WS_MAX_CONNECTIONS_PER_IP=30
WS_REQUIRE_SUBSCRIBE_SECONDS=15
WS_MAX_SUBSCRIPTIONS=200
WS_SERVER_PING_INTERVAL_SECONDS=30
WS_SERVER_PONG_TIMEOUT_SECONDS=15
WS_MAX_MESSAGE_BYTES=32768

# Optional: npm run smoke:endpoints (dev server must be running). Override host:
# SMOKE_BASE_URL=http://127.0.0.1:3050
# Skip DB check: SMOKE_SKIP_DB=1

# Blockchain
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VITE_CHAIN_ID=8453
# Base Sepolia testnet: VITE_CHAIN_ID=84532 (and matching VITE_USDC_ADDRESS if you use test USDC)
# Mock wallet: ONLY when VITE_WALLET_MOCK_CONNECT=1 AND the app is a non-production Vite build (import.meta.env.PROD is false). Never set on Vercel production.
# VITE_WALLET_MOCK_CONNECT=
# Optional mock address (lowercase 0x…); default is a fixed dev address if unset.
# VITE_WALLET_MOCK_ADDRESS=
# Dev-only: log eth_accounts / hydration path (requires import.meta.env.DEV).
# VITE_WALLET_IDENTITY_DEBUG=
# Dev-only: fixed overlay with wallet runtime + scroll lock depths (`vite dev` only).
# VITE_WALLET_RUNTIME_DEBUG=

VITE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Wallet Connect (optional for demo mode)
VITE_WALLETCONNECT_PROJECT_ID=

# Azuro Protocol (optional for demo mode)
VITE_AZURO_API_URL=https://thegraph.com/hosted-service/subgraph/azuro-protocol/azuro-api-gnosis
VITE_AZURO_API_KEY=
VITE_AZURO_CHAIN_ID=100

# Vinxi HTTP handlers: JSON request diagnostics (method, pathname, status, durationMs). On when NODE_ENV=development.
# RUNTIME_HANDLER_DEBUG=1

# Server: min ms between Azuro GraphQL market snapshots on paper trade (default 45000)
AZURO_MARKET_REFRESH_MS=45000
# Azuro V3 (tRPC / server): Polygon data-feed — required for games list + V3 fields (state, currentOdds)
AZURO_DATA_FEED_URL=https://thegraph-1.onchainfeed.org/subgraphs/name/azuro-protocol/azuro-data-feed-polygon
# Optional legacy override; if unset, `services/azuro.ts` defaults to AZURO_DATA_FEED_URL above
# AZURO_GRAPHQL_URL=

# AI Chatbot (Required for chatbot functionality)
# Get your API key from https://openrouter.ai/
VITE_OPENROUTER_KEY=sk-or-v1-...
OPENROUTER_KEY=sk-or-v1-...

# Error Monitoring (Optional - for Sentry or similar services)
VITE_ERROR_MONITORING_DSN=
VITE_ERROR_MONITORING_ENVIRONMENT=production
VITE_APP_VERSION=1.0.0
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Treasury and Founder
TREASURY_WALLET=0x0000000000000000000000000000000000000000
FOUNDER_WALLET=0x0000000000000000000000000000000000000000
FOUNDER_REF_CODE=PREDICTIO

# Fee constants (do not change)
FEE_VAULT=0.50
FEE_ANALYST=0.35
FEE_REFERRAL=0.15
TAKER_FEE_RATE=0.01

# Payout
PAYOUT_THRESHOLD_EUR=10
USDC_EUR_RATE=0.92

# Cookie
REFERRAL_COOKIE_DAYS=120
REFERRAL_COOKIE_NAME=predictio_ref

# Chain (keep BASE_CHAIN_ID aligned with VITE_CHAIN_ID so server AI prompts match the SPA network)
BASE_CHAIN_ID=8453
BASE_SEPOLIA_CHAIN_ID=84532
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Contracts (when available)
CTF_CONTRACT_ADDRESS=
CTF_EXCHANGE_ADDRESS=
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
