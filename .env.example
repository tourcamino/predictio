# Predictio.live — Environment Variables
# Copy to .env / .env.local and fill in values
# See /docs/ENV.md for full documentation

# Database (required for real data — C1)
# Local Docker: docker compose -f docker-compose.dev.yml up -d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/predictio

# Application
VITE_APP_NAME=Predictio
VITE_APP_URL=
VITE_API_URL=
VITE_ENVIRONMENT=development

# Backend (VPS) security keys (C2)
# - ADMIN_API_KEY: required to call /api/admin/* and /api/developer/keys
# - BOT_API_KEY: used by bots and some internal admin tooling
ADMIN_API_KEY=
BOT_API_KEY=

# Backend enforcement toggles (prod hardening)
WRITE_AUTH_REQUIRED=1

# HTTP hardening
HTTP_JSON_BODY_LIMIT=128kb

# Usage retention (days)
API_USAGE_RETENTION_DAYS=30

# WebSocket hardening (C3+ hardening)
WS_AUTH_REQUIRED=1
WS_MAX_CONNECTIONS_PER_IP=30
WS_REQUIRE_SUBSCRIBE_SECONDS=15
WS_MAX_SUBSCRIPTIONS=200
WS_SERVER_PING_INTERVAL_SECONDS=30
WS_SERVER_PONG_TIMEOUT_SECONDS=15
WS_MAX_MESSAGE_BYTES=32768

# Optional: npm run smoke:endpoints (dev server must be running). Override host:
# SMOKE_BASE_URL=http://127.0.0.1:3050
# Skip DB check: SMOKE_SKIP_DB=1

# Blockchain
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VITE_CHAIN_ID=8453
VITE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Wallet Connect (optional for demo mode)
VITE_WALLETCONNECT_PROJECT_ID=

# Azuro Protocol (optional for demo mode)
VITE_AZURO_API_URL=https://thegraph.com/hosted-service/subgraph/azuro-protocol/azuro-api-gnosis
VITE_AZURO_API_KEY=
VITE_AZURO_CHAIN_ID=100

# Server: min ms between Azuro GraphQL market snapshots on paper trade (default 45000)
AZURO_MARKET_REFRESH_MS=45000

# AI Chatbot (Required for chatbot functionality)
# Get your API key from https://openrouter.ai/
VITE_OPENROUTER_KEY=sk-or-v1-...
OPENROUTER_KEY=sk-or-v1-...

# Error Monitoring (Optional - for Sentry or similar services)
VITE_ERROR_MONITORING_DSN=
VITE_ERROR_MONITORING_ENVIRONMENT=production
VITE_APP_VERSION=1.0.0
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Treasury and Founder
TREASURY_WALLET=0x0000000000000000000000000000000000000000
FOUNDER_WALLET=0x0000000000000000000000000000000000000000
FOUNDER_REF_CODE=PREDICTIO

# Fee constants (do not change)
FEE_VAULT=0.50
FEE_ANALYST=0.35
FEE_REFERRAL=0.15
TAKER_FEE_RATE=0.01

# Payout
PAYOUT_THRESHOLD_EUR=10
USDC_EUR_RATE=0.92

# Cookie
REFERRAL_COOKIE_DAYS=120
REFERRAL_COOKIE_NAME=predictio_ref

# Chain
BASE_CHAIN_ID=8453
BASE_SEPOLIA_CHAIN_ID=84532
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Contracts (when available)
CTF_CONTRACT_ADDRESS=
CTF_EXCHANGE_ADDRESS=
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
