{
  "name": "predictio-backend",
  "version": "1.0.0",
  "description": "Predictio REST API and WebSocket server",
  "main": "dist/index.js",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "node --dns-result-order=ipv4first --env-file=.env --import tsx src/index.ts",
    "build": "tsc",
    "start": "node --dns-result-order=ipv4first dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "publish-events": "node --env-file=.env --import tsx src/scripts/publishEvents.ts",
    "debug:dump-azuro": "node --env-file=.env --import tsx src/scripts/debug/dumpRawAzuroFeed.ts",
    "debug:trace-raw-feed": "node --env-file=.env --import tsx src/scripts/debug/traceRawAzuroFeed.ts",
    "debug:trace-home-pipeline": "node --env-file=.env --import tsx src/scripts/debug/traceHomePipeline.ts",
    "debug:trace-curated-lifecycle": "node --env-file=.env --import tsx src/scripts/debug/traceCuratedEventLifecycle.ts",
    "debug:filter-waterfall": "node --env-file=.env --import tsx src/scripts/debug/filterWaterfallDiagnostics.ts",
    "debug:frontend-backend-diff": "node --env-file=.env --import tsx src/scripts/debug/frontendBackendDiff.ts",
    "debug:env-audit": "node --env-file=.env --import tsx src/scripts/debug/productionEnvAudit.ts",
    "debug:normalization": "node --env-file=.env --import tsx src/scripts/debug/normalizationFailures.ts",
    "debug:sport-density": "node --env-file=.env --import tsx src/scripts/debug/sportDensityMap.ts",
    "debug:temporal-windows": "node --env-file=.env --import tsx src/scripts/debug/temporalWindowDensity.ts",
    "debug:validate-registry": "node --env-file=.env --import tsx src/scripts/debug/validateRegistryIntegrity.ts",
    "test:football-first-guards": "node --import tsx src/scripts/test/footballFirstGuards.test.ts",
    "test:lp-graph-guards": "node --import tsx src/scripts/test/lpGraphGuards.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "bcryptjs": "^3.0.3",
    "ethers": "^6.16.0",
    "google-translate-api-x": "^10.7.2",
    "redis": "^5.8.2",
    "ws": "^8.16.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "prisma": "^6.8.2"
  }
}
